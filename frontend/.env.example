# Backend API
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Auth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Mock mode (set to "true" to use MSW mocks instead of real API)
NEXT_PUBLIC_USE_MOCK=true

# AI (if using Vercel AI SDK with OpenAI directly - optional)
# OPENAI_API_KEY=sk-...
